# Copy this file to `secrets.toml` (same folder) when running locally,
# OR paste these key-value pairs into Streamlit Cloud's Secrets manager.
# DO NOT commit secrets.toml — it is gitignored.

# Direct HTTPS link to the policy PDF, OR a Google Drive share link.
# For Google Drive: set the file's sharing to "Anyone with the link" (Viewer),
# then paste the full /file/d/.../view URL here.
PDF_URL = "https://drive.google.com/file/d/REPLACE_WITH_YOUR_FILE_ID/view"

# Optional: pin a specific embedding model. Defaults to BAAI/bge-base-en-v1.5.
# EMBEDDING_MODEL = "BAAI/bge-base-en-v1.5"
